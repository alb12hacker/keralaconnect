{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A live transit vehicle (bus, ferry).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "type": { "type": "string", "enum": ["bus", "ferry"] },
        "routeNumber": { "type": "string" },
        "routeName": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "heading": { "type": "number" },
        "speed": { "type": "number" },
        "crowdLevel": { "type": "string", "enum": ["empty", "moderate", "crowded", "full"] },
        "status": { "type": "string", "enum": ["active", "delayed", "inactive"] },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "driverId", "type", "routeNumber", "routeName", "lat", "lng", "heading", "speed", "crowdLevel", "status", "lastUpdated"]
    },
    "UserSavedRoute": {
      "title": "User Saved Route",
      "description": "A route saved by the user for quick access.",
      "type": "object",
      "properties": {
        "routeId": { "type": "string" },
        "routeName": { "type": "string" },
        "type": { "type": "string", "enum": ["school", "college", "tuition", "work", "general"] },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["routeId", "routeName", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/savedRoutes/{routeId}": {
      "schema": { "$ref": "#/entities/UserSavedRoute" },
      "description": "User's saved routes"
    },
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Live tracking data of vehicles"
    }
  }
}
